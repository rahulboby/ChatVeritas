{
  "model": {
    "base_model": "Qwen/Qwen2.5-3B-Instruct",
    "adapter_repo_id": "rahulboby/chatveritas-lora-adapter",
    "adapter_path": "models/adapters"
  },

  "embedding": {
    "model": "sentence-transformers/all-MiniLM-L6-v2",
    "device": "cpu"
  },

  "reranker": {
    "model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
    "device": "cpu"
  },

  "retrieval": {
    "top_k": 5,
    "chunk_size": 1000,
    "chunk_overlap": 80,
    "faiss_candidates": 30
  },

  "generation": {
    "max_new_tokens": 2048,
    "temperature": 0.3
  },

  "paths": {
    "raw_data": "data/raw",
    "vectorstore": "data/vectorstore",
    "processed_data": "data/processed/train.jsonl",
    "training_checkpoints": "models/checkpoints"
  },

  "dataset": {
    "max_chunk_tokens": 500
  },

  "llm": {
    "provider": "groq",
    "model": "openai/gpt-oss-120b",
    "temperature": 0.7,
    "max_retries": 3
  },

  "cache": {
    "enabled": true,
    "directory": "data/cache"
  },

  "training": {
    "epochs": 3,
    "batch_size": 2,
    "gradient_accumulation": 8,
    "learning_rate": 0.0002,
    "max_sequence_length": 2048
  },

  "lora": {
    "r": 16,
    "alpha": 32,
    "dropout": 0.05,
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"]
  }
}